{
  "rules": [
    {
      "pattern": "frontend-react/src/components/**/*.{tsx,js}",
      "description": "Component structure and organization",
      "conventions": [
        "Components should be organized in CamelCase named folders (e.g., ComponentName/)",
        "Each component folder must contain: index.js (entry point)",
        "Include style.module.scss for component-specific styles",
        "Optional animation.js for component animations and logic",
        "Group components by type in ui/, pages/, or layouts/ subdirectories"
      ]
    },
    {
      "pattern": "frontend-react/src/styles/**/*.scss",
      "description": "Styling structure",
      "conventions": [
        "Use .module.scss for component-specific styles",
        "Keep styles scoped to their respective components",
        "Follow BEM-like naming convention for classes"
      ]
    },
    {
      "pattern": "frontend-react/src/app/**/*.{tsx,js}",
      "description": "Next.js app router pages and layouts",
      "conventions": [
        "Use the app directory for all routes and pages",
        "Keep page-specific components in their respective route folders",
        "Follow Next.js file conventions (page.tsx, layout.tsx)"
      ]
    },
    {
      "pattern": "frontend-react/src/hooks/**/*.{ts,js}",
      "description": "Custom React hooks",
      "conventions": [
        "Create hooks in individual files",
        "Use camelCase naming for hook files",
        "Export hooks as named exports"
      ]
    },
    {
      "pattern": "frontend-react/src/context/**/*.{tsx,js}",
      "description": "React context providers",
      "conventions": [
        "Create context providers in individual files",
        "Export context and provider as named exports",
        "Include types for context values"
      ]
    },
    {
      "pattern": "frontend-react/src/lib/**/*.{ts,js}",
      "description": "Utility functions and helpers",
      "conventions": [
        "Group utilities by functionality",
        "Export utilities as named exports",
        "Keep functions pure and focused"
      ]
    },
    {
      "pattern": "app/**/*.tsx",
      "description": "Next.js app router components and pages",
      "conventions": [
        "Use the app directory for all routes and pages",
        "Keep components specific to a route in its directory",
        "Follow the naming convention: page.tsx for pages, layout.tsx for layouts",
        "Use loading.tsx for loading states and error.tsx for error boundaries"
      ]
    },
    {
      "pattern": "app/api/**/*.ts",
      "description": "API route handlers",
      "conventions": [
        "Organize API routes by feature/resource",
        "Use HTTP method handlers (GET, POST, etc.)",
        "Implement proper error handling and validation",
        "Keep authentication middleware separate"
      ]
    },
    {
      "pattern": "components/**/*.tsx",
      "description": "Reusable UI components",
      "conventions": [
        "Group components by feature or type",
        "Keep components small and focused",
        "Use ShadCN UI components when possible",
        "Implement proper TypeScript interfaces"
      ]
    },
    {
      "pattern": "lib/**/*.ts",
      "description": "Shared utilities and helpers",
      "conventions": [
        "Organize by functionality (auth, db, api)",
        "Keep utility functions pure and testable",
        "Use TypeScript for type safety",
        "Document complex functions"
      ]
    },
    {
      "pattern": "prisma/**/*.prisma",
      "description": "Database schema and migrations",
      "conventions": [
        "Keep schema.prisma up to date",
        "Document model relationships",
        "Use meaningful field names",
        "Include proper indexes and constraints"
      ]
    },
    {
      "pattern": "styles/**/*.css",
      "description": "Global styles and Tailwind configurations",
      "conventions": [
        "Use Tailwind CSS classes when possible",
        "Keep custom CSS minimal",
        "Organize global styles logically",
        "Document custom utility classes"
      ]
    },
    {
      "pattern": "types/**/*.ts",
      "description": "TypeScript type definitions",
      "conventions": [
        "Define shared interfaces and types",
        "Use descriptive type names",
        "Keep types DRY",
        "Export types properly"
      ]
    },
    {
      "pattern": "config/**/*.ts",
      "description": "Configuration files",
      "conventions": [
        "Keep environment variables organized",
        "Document configuration options",
        "Use TypeScript for type safety",
        "Separate concerns (auth, api, etc.)"
      ]
    },
    {
      "pattern": "__tests__/**/*.test.ts",
      "description": "Test files",
      "conventions": [
        "Organize tests by feature",
        "Follow testing best practices",
        "Include unit and integration tests",
        "Use meaningful test descriptions"
      ]
    }
  ],
  "ignore": [
    "node_modules",
    ".next",
    "build",
    "dist",
    "coverage",
    ".env*",
    "*.log",
    ".DS_Store"
  ]
} 